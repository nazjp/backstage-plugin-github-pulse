    "description": "GitHub Pulse-style activity for Backstage (scmAuthApi + Octokit).",
    "license": "Apache-2.0",
    "repository": {
      "type": "git",
      "url": "https://github.com/nazjp/backstage-plugin-github-pulse"
    },
