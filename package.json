      "@backstage/core-plugin-api": "^1.12.0",
      "@backstage/integration-react": "^1.2.0",
      "@backstage/plugin-catalog-react": "^1.21.0",
      "@material-ui/core": "^4.12.2",
      "@octokit/rest": "^19.0.0",
      "luxon": "^3.4.0",
      "react-use": "^17.4.0",
      "recharts": "^2.12.0"
