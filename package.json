      "@types/jest": "^29.5.0",
      "@types/luxon": "^3.4.0",
      "@types/react": "^18.0.0",
      "@types/react-dom": "^18.0.0",
      "react": "^18.0.0",
      "react-dom": "^18.0.0",
      "react-router-dom": "^6.3.0",
      "typescript": "~5.8.0"
    },
    "peerDependencies": {
      "react": "^17.0.0 || ^18.0.0",
